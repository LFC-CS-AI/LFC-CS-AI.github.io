{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lfc-visitor-analytics",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lfc-visitor-analytics-db"
    }
  ],
  "vars": {
    "SITE_ORIGIN": "https://lfc-cs-ai.github.io"
  }
}
